[Unit]
Description=MarginWatch web service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/marginwatch/MarginWatch
EnvironmentFile=/etc/marginwatch.env
ExecStart=/opt/marginwatch/MarginWatch/venv/bin/gunicorn \
    --workers 1 \
    --bind 0.0.0.0:6000 \
    main_web:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
